# Chave pública do Mercado Pago (não é secreta, pode ficar no build do frontend).
# Pegue em: https://www.mercadopago.com.br/developers/panel/app > Credenciais de produção
VITE_MP_PUBLIC_KEY=

# Access Token do Mercado Pago (SECRETO — nunca commitar).
# Configure como variável de ambiente direto no painel da Vercel (Settings > Environment Variables),
# nunca neste arquivo nem no repositório.
MERCADOPAGO_ACCESS_TOKEN=
